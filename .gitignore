*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
ENV/

# Packaging
dist/
build/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# Pytest
